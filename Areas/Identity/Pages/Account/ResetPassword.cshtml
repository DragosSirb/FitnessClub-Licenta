@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Resetare parolă";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <span class="fs-3 fw-bold">Fitness<span class="text-accent">Club</span></span>
            <p class="text-muted mt-1 mb-0">Setează o parolă nouă</p>
        </div>

        @if (Model.Succeeded)
        {
            <div class="card p-4 text-center">
                <i class="bi bi-check-circle fs-1 text-accent mb-3"></i>
                <h5 class="mb-2">Parolă schimbată</h5>
                <p class="text-muted small mb-3">Parola ta a fost resetată cu succes. Te poți conecta acum.</p>
                <a asp-page="./Login" class="btn btn-primary w-100">Conectează-te</a>
            </div>
        }
        else if (Model.InvalidLink)
        {
            <div class="card p-4 text-center">
                <i class="bi bi-x-circle fs-1 text-danger mb-3"></i>
                <h5 class="mb-2">Link invalid</h5>
                <p class="text-muted small mb-3">Link-ul de resetare este invalid sau a expirat. Solicită unul nou.</p>
                <a asp-page="./ForgotPassword" class="btn btn-outline-secondary w-100">Încearcă din nou</a>
            </div>
        }
        else
        {
            <div class="card p-4">
                <form method="post">
                    <input type="hidden" asp-for="Input.Code" />
                    <input type="hidden" asp-for="Input.Email" />
                    <div class="mb-3">
                        <label class="form-label">Parolă nouă</label>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Minim 6 caractere" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirmă parola</label>
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Salvează parola nouă</button>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
