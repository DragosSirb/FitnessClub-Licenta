@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperare parolă";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <span class="fs-3 fw-bold">Fitness<span class="text-accent">Club</span></span>
            <p class="text-muted mt-1 mb-0">Recuperare parolă</p>
        </div>

        @if (Model.Sent)
        {
            <div class="card p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-shield-check fs-1 text-accent"></i>
                </div>
                <h5 class="mb-2">Cerere trimisă</h5>
                <p class="text-muted small mb-3">
                    Administratorul a fost notificat și te va contacta în cel mai scurt timp pentru a te ajuta să îți recuperezi accesul.
                </p>
                <a asp-page="./Login" class="btn btn-outline-secondary w-100">Înapoi la conectare</a>
            </div>
        }
        else
        {
            <div class="card p-4">
                <p class="text-muted small mb-3">Introdu adresa de email asociată contului tău și îți trimitem un link de resetare a parolei.</p>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="adresa@exemplu.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Trimite cererea</button>
                </form>
                <p class="text-center text-muted small mt-4 mb-0">
                    <a asp-page="./Login">Înapoi la conectare</a>
                </p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
