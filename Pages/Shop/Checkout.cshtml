@page
@model FitnessClub.Pages.Shop.CheckoutModel
@{
    ViewData["Title"] = "Finalizare comandă";
}

<h2 class="mb-4">Finalizare comandă</h2>

<div class="row">
    <div class="col-md-7">
        <div class="card p-4 mb-3">
            <h5 class="mb-3">Sumar comandă</h5>
            <table class="table">
                <thead>
                    <tr>
                        <th>Produs</th>
                        <th>Cant.</th>
                        <th class="text-end">Preț</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (product, qty) in Model.CartItems)
                    {
                        <tr>
                            <td>@product.Name</td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <form method="post" asp-page-handler="DecreaseQty">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm px-2 py-0 lh-1">−</button>
                                    </form>
                                    <span class="mx-1 fw-semibold">@qty</span>
                                    <form method="post" asp-page-handler="IncreaseQty">
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm px-2 py-0 lh-1">+</button>
                                    </form>
                                </div>
                            </td>
                            <td class="text-end">@product.Price RON</td>
                            <td class="text-end">@(product.Price * qty) RON</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Total:</td>
                        <td class="text-end fw-bold text-purple">@Model.Total RON</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="col-md-5">
        @if (Model.ClientSecret == null)
        {
            <div class="card p-4">
                <h5 class="mb-3">Metodă de plată</h5>
                <p class="text-muted small">Ridicarea comenzii este disponibilă numai la sediul nostru.</p>
                <form method="post">
                    <div class="mb-3">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="Online" id="payOnline" checked />
                            <label class="form-check-label" for="payOnline">
                                <i class="bi bi-credit-card me-1"></i>Online (card)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="InPerson" id="payGym" />
                            <label class="form-check-label" for="payGym">
                                <i class="bi bi-building me-1"></i>Plată la sală (ridicare personală)
                            </label>
                        </div>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Plasează comanda</button>
                        <a asp-page="/Shop/Index" class="btn btn-outline-secondary">Înapoi la magazin</a>
                    </div>
                </form>
            </div>
        }
        else
        {
            <form id="payment-form">
                <div id="payment-element"></div>
                <button id="submit">
                    <div class="spinner hidden" id="spinner"></div>
                    <span id="button-text">Plătește acum</span>
                </button>
                <div id="payment-message" class="hidden"></div>
            </form>
        }
    </div>
    @if (Model.ClientSecret != null)
    {
        <script src="https://js.stripe.com/v3/"></script>
        <script>
            const stripe = Stripe('@Model.PublishableKey');
            const clientSecret = '@Model.ClientSecret';
            const elements = stripe.elements({ clientSecret });
            const paymentElement = elements.create('payment');
            paymentElement.mount('#payment-element');
            const form = document.getElementById('payment-form');
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const { error } = await stripe.confirmPayment({
                    elements,
                    confirmParams: { return_url: 'http://localhost:5200/Payment/Success?type=order' }
                });
                if (error) document.getElementById('payment-message').textContent = error.message;
            });
        </script>
    }
</div>
