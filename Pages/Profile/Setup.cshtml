@page
@model FitnessClub.Pages.Profile.SetupModel
@{
    ViewData["Title"] = "Completează-ți profilul";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="text-center mb-4">
            <i class="bi bi-person-circle text-accent" style="font-size:2.5rem"></i>
            <h2 class="mt-2 mb-1">Completează-ți profilul</h2>
            <p class="text-muted">Câteva detalii și ești gata să începi!</p>
        </div>
        <div class="card p-4">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label">Prenume *</label>
                        <input class="form-control" asp-for="Input.FirstName" />
                        <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Nume *</label>
                        <input class="form-control" asp-for="Input.LastName" />
                        <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label">Data nașterii *</label>
                        <input class="form-control" asp-for="Input.DateOfBirth" type="date" />
                        <span asp-validation-for="Input.DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Sex *</label>
                        <select class="form-select" asp-for="Input.Gender">
                            <option value="">-- Selectează --</option>
                            <option value="Male">Masculin</option>
                            <option value="Female">Feminin</option>
                            <option value="Other">Altul</option>
                        </select>
                        <span asp-validation-for="Input.Gender" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Telefon *</label>
                    <input class="form-control" asp-for="Input.Phone" />
                    <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Adresă *</label>
                    <input class="form-control" asp-for="Input.Address" />
                    <span asp-validation-for="Input.Address" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Greutate țintă (kg) <span class="text-muted fw-normal">(opțional)</span></label>
                    <input class="form-control" asp-for="Input.GoalWeight" type="number" step="0.1" min="0" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Fotografie de profil <span class="text-muted fw-normal">(opțional)</span></label>
                    <input class="form-control" type="file" asp-for="Input.ProfilePhoto" accept="image/*" />
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-check-circle me-2"></i>Salvează și continuă
                </button>
            </form>
        </div>
    </div>
</div>

@if (TempData["ProfileCompleted"] != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.6)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-5">
                <i class="bi bi-check-circle-fill text-accent mb-3" style="font-size:3rem"></i>
                <h4 class="mb-2">Profil completat!</h4>
                <p class="text-muted mb-4">Bine ai venit la FitnessClub. Să începem!</p>
                <a asp-page="/Member/Dashboard" class="btn btn-primary">Mergi la panou</a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
