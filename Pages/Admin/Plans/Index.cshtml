@page
@model FitnessClub.Pages.Admin.Plans.IndexModel
@using FitnessClub.Models.Enums
@{
    ViewData["Title"] = "Planuri de abonament";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Planuri de abonament</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
        <i class="bi bi-plus-lg me-1"></i>Adaugă plan
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr><th>Nume</th><th>Tip</th><th>Preț</th><th>Durată</th><th>Clase grup</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var plan in Model.Plans)
            {
                <tr>
                    <td><strong>@plan.Name</strong><br /><small class="text-muted">@plan.Description</small></td>
                    <td><span class="badge bg-secondary">@plan.Type</span></td>
                    <td>@plan.Price RON</td>
                    <td>@plan.DurationDays zile</td>
                    <td><span class="badge @(plan.IncludesGroupClasses ? "bg-success" : "bg-secondary")">@(plan.IncludesGroupClasses ? "Da" : "Nu")</span></td>
                    <td><span class="badge @(plan.IsActive ? "bg-success" : "bg-danger")">@(plan.IsActive ? "Activ" : "Inactiv")</span></td>
                    <td class="text-end">
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><button type="button" class="dropdown-item" onclick="openPlanEdit(@plan.Id)"><i class="bi bi-pencil me-1"></i>Editează</button></li>
                                <li>
                                    <form method="post" asp-page-handler="Toggle">
                                        <input type="hidden" name="id" value="@plan.Id" />
                                        <button type="submit" class="dropdown-item @(plan.IsActive ? "text-warning" : "text-success")">@(plan.IsActive ? "Dezactivează" : "Activează")</button>
                                    </form>
                                </li>
                                <li>
                                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Ștergi acest plan?')">
                                        <input type="hidden" name="id" value="@plan.Id" />
                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-1"></i>Șterge</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
                <tr id="plan-edit-@plan.Id" style="display:none" class="table-active">
                    <td colspan="7">
                        <form method="post" asp-page-handler="EditPlan" class="row g-2 align-items-end p-2">
                            <input type="hidden" name="planId" value="@plan.Id" />
                            <div class="col-md-2"><label class="form-label small mb-1">Nume</label><input type="text" name="name" class="form-control form-control-sm" value="@plan.Name" required /></div>
                            <div class="col-md-2"><label class="form-label small mb-1">Preț (RON)</label><input type="number" name="price" step="0.01" min="0" class="form-control form-control-sm" value="@plan.Price" required /></div>
                            <div class="col-md-2"><label class="form-label small mb-1">Durată (zile)</label><input type="number" name="durationDays" min="1" class="form-control form-control-sm" value="@plan.DurationDays" required /></div>
                            <div class="col-md-3"><label class="form-label small mb-1">Descriere</label><input type="text" name="description" class="form-control form-control-sm" value="@plan.Description" /></div>
                            <div class="col-md-1">
                                <div class="form-check mt-4">
                                    <input type="hidden" name="includesGroupClasses" value="false" />
                                    <input class="form-check-input" type="checkbox" name="includesGroupClasses" value="true" @(plan.IncludesGroupClasses ? "checked" : "") />
                                    <label class="form-check-label small">Clase</label>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex gap-2">
                                <button type="submit" class="btn btn-sm btn-primary">Gata</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="closePlanEdit(@plan.Id)">&#x2715;</button>
                            </div>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Adaugă plan nou</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Nume *</label><input class="form-control" asp-for="Input.Name" /></div>
                    <div class="mb-3">
                        <label class="form-label">Tip *</label>
                        <select class="form-select" asp-for="Input.Type">
                            <option value="Subscription">Abonament</option>
                            <option value="DayPass">Bilet de zi</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3"><label class="form-label">Preț (RON) *</label><input class="form-control" asp-for="Input.Price" type="number" step="0.01" min="0" /></div>
                        <div class="col-6 mb-3"><label class="form-label">Durată (zile) *</label><input class="form-control" asp-for="Input.DurationDays" type="number" min="0" /></div>
                    </div>
                    <div class="mb-3"><label class="form-label">Descriere</label><textarea class="form-control" asp-for="Input.Description" rows="2"></textarea></div>
                    <div class="form-check mb-3"><input class="form-check-input" asp-for="Input.IncludesGroupClasses" /><label class="form-check-label" asp-for="Input.IncludesGroupClasses">Include clase de grup</label></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anulează</button>
                    <button type="submit" class="btn btn-primary">Creează</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openPlanEdit(id) {
            document.querySelectorAll('[id^="plan-edit-"]').forEach(function (r) { r.style.display = 'none'; });
            document.getElementById('plan-edit-' + id).style.display = '';
        }
        function closePlanEdit(id) { document.getElementById('plan-edit-' + id).style.display = 'none'; }
    </script>
}
