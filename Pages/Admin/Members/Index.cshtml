@page
@model FitnessClub.Pages.Admin.Members.IndexModel
@using FitnessClub.Models.Enums
@{
    ViewData["Title"] = "Membri";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Membri</h2>
    <span class="text-muted">@Model.Members.Count total</span>
</div>

<form method="get" class="mb-3 d-flex gap-2">
    <input class="form-control" asp-for="Search" placeholder="Caută după nume sau email..." style="max-width:300px" />
    <button type="submit" class="btn btn-outline-primary">Caută</button>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <a asp-page="/Admin/Members/Index" class="btn btn-outline-secondary">Șterge filtrul</a>
    }
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Nume</th>
                <th>Email</th>
                <th>Telefon</th>
                <th>Abonament</th>
                <th>Sesiuni</th>
                <th>Comenzi</th>
                <th>Status</th>
                <th>Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var detail in Model.Members)
            {
                <tr style="cursor:pointer" onclick="window.location='/Admin/Members/Detail/@detail.Member.Id'">
                    <td>@detail.Member.FirstName @detail.Member.LastName</td>
                    <td>@detail.Member.User.Email</td>
                    <td>@detail.Member.Phone</td>
                    <td>
                        @if (detail.ActiveSubscription != null)
                        {
                            <span class="badge bg-success">@detail.ActiveSubscription.Plan.Name</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Niciun plan</span>
                        }
                    </td>
                    <td>@detail.TotalSessions</td>
                    <td>@detail.TotalOrders</td>
                    <td>
                        <span class="badge @(detail.Member.IsActive ? "bg-success" : "bg-danger")">
                            @(detail.Member.IsActive ? "Activ" : "Inactiv")
                        </span>
                    </td>
                    <td onclick="event.stopPropagation()">
                        <form method="post" asp-page-handler="ToggleActive" class="d-inline">
                            <input type="hidden" name="memberId" value="@detail.Member.Id" />
                            <button type="submit" class="btn btn-sm @(detail.Member.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                @(detail.Member.IsActive ? "Dezactivează" : "Activează")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Members.Any())
{
    <div class="text-center text-muted p-4">Nu s-au găsit membri.</div>
}
