@page
@model FitnessClub.Pages.Admin.Dashboard.IndexModel
@{
    ViewData["Title"] = "Panou de administrare";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="mb-0">Panou de administrare</h2>
    <span class="text-muted small">@DateTime.Today.ToString("dddd, dd MMMM yyyy")</span>
</div>

@if (Model.LowStockAlerts.Any())
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
        <i class="bi bi-exclamation-triangle fs-5 flex-shrink-0"></i>
        <div>
            <strong>Stoc redus:</strong> @string.Join(", ", Model.LowStockAlerts)
            <a asp-page="/Admin/Shop/Index" class="alert-link ms-2">Administrează</a>
        </div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card p-4 h-100">
            <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Membri totali</div>
            <div class="display-6 fw-bold text-accent">@Model.TotalMembers</div>
            <a asp-page="/Admin/Members/Index" class="text-muted small mt-2 d-inline-block">Vezi toți →</a>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card p-4 h-100">
            <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Abonamente active</div>
            <div class="display-6 fw-bold text-accent">@Model.ActiveSubscriptions</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card p-4 h-100">
            <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Venituri luna aceasta</div>
            <div class="display-6 fw-bold text-accent">@Model.RevenueThisMonth.ToString("F0")</div>
            <div class="text-muted small">RON</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card p-4 h-100">
            <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Comenzi în așteptare</div>
            <div class="display-6 fw-bold @(Model.PendingOrders > 0 ? "text-accent" : "text-muted")">@Model.PendingOrders</div>
            <a asp-page="/Admin/Orders/Index" class="text-muted small mt-2 d-inline-block">Vezi toate →</a>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card p-4">
            <div class="fw-semibold mb-3">Venituri — ultimele 6 luni</div>
            <canvas id="revenueChart" height="90"></canvas>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header fw-semibold">Activitate recentă</div>
            <div class="card-body p-0">
                @if (!Model.RecentActivities.Any())
                {
                    <div class="p-4 text-muted small">Nu există activitate recentă.</div>
                }
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="d-flex gap-3 px-4 py-3" style="border-bottom:1px solid var(--border)">
                        <i class="bi bi-circle-fill text-accent flex-shrink-0" style="font-size:0.45rem;margin-top:0.5rem"></i>
                        <div>
                            <div class="small">@activity.Description</div>
                            <div class="text-muted" style="font-size:0.75rem">@activity.Date.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.RevenueChart.Select(r => $"\"{r.Month}\"")))],
                datasets: [{
                    label: 'RON',
                    data: [@Html.Raw(string.Join(",", Model.RevenueChart.Select(r => r.Revenue)))],
                    backgroundColor: 'rgba(46,204,113,0.25)',
                    borderColor: '#2ecc71',
                    borderWidth: 2,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#8b949e' } },
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#8b949e' } }
                }
            }
        });
    </script>
}
