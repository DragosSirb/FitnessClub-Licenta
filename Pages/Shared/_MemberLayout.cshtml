<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitnessClub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FitnessClub.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <script src="https://js.stripe.com/v3/"></script>
</head>
<body class="d-flex flex-column min-vh-100">
    @{
        var unreadCount = ViewData["UnreadNotifications"] as int? ?? 0;
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        Func<string, string> navCls = page =>
            currentPage == page
                ? "nav-link active d-flex align-items-center gap-2 px-3 py-2 rounded"
                : "nav-link d-flex align-items-center gap-2 px-3 py-2 rounded";
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    Fitness<span class="text-purple">Club</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Shop/Index">Shop</a></li>
                        <li class="nav-item d-lg-none"><hr class="dropdown-divider my-1" /></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Dashboard">Dashboard</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/BookSession">Book Session</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Classes">Classes</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Events">Events</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Subscription">Subscription</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Orders">Orders</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Progress">Progress</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Profile">Profile</a></li>
                        <li class="nav-item d-lg-none"><a class="nav-link" asp-page="/Member/Notifications">Notifications</a></li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-2">
                            <a class="nav-link position-relative" asp-page="/Member/Notifications">
                                <i class="bi bi-bell fs-5"></i>
                                @if (unreadCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem">
                                        @unreadCount
                                    </span>
                                }
                            </a>
                        </li>
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="d-flex flex-grow-1">
        <nav class="d-none d-lg-block bg-white border-end py-3 flex-shrink-0" style="width:220px;">
            <ul class="nav flex-column px-2 gap-1">
                <li class="nav-item">
                    <a class="@navCls("/Member/Dashboard")" asp-page="/Member/Dashboard">
                        <i class="bi bi-speedometer2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@navCls("/Member/BookSession")" asp-page="/Member/BookSession">
                        <i class="bi bi-calendar-plus"></i>Book Session
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@(currentPage == "/Member/Classes" || currentPage == "/Member/ClassDetail" ? "nav-link active d-flex align-items-center gap-2 px-3 py-2 rounded" : "nav-link d-flex align-items-center gap-2 px-3 py-2 rounded")" asp-page="/Member/Classes">
                        <i class="bi bi-people"></i>Classes
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@(currentPage == "/Member/Events" || currentPage == "/Member/EventDetail" ? "nav-link active d-flex align-items-center gap-2 px-3 py-2 rounded" : "nav-link d-flex align-items-center gap-2 px-3 py-2 rounded")" asp-page="/Member/Events">
                        <i class="bi bi-calendar-event"></i>Events
                    </a>
                </li>
                <li><hr class="my-2" /></li>
                <li class="nav-item">
                    <a class="@(currentPage == "/Member/Subscription" || currentPage == "/Member/Plans" || currentPage == "/Member/BuyPlan" ? "nav-link active d-flex align-items-center gap-2 px-3 py-2 rounded" : "nav-link d-flex align-items-center gap-2 px-3 py-2 rounded")" asp-page="/Member/Subscription">
                        <i class="bi bi-credit-card"></i>Subscription
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@navCls("/Member/Orders")" asp-page="/Member/Orders">
                        <i class="bi bi-bag"></i>Orders
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@navCls("/Member/Progress")" asp-page="/Member/Progress">
                        <i class="bi bi-graph-up"></i>Progress
                    </a>
                </li>
                <li><hr class="my-2" /></li>
                <li class="nav-item">
                    <a class="@navCls("/Member/Profile")" asp-page="/Member/Profile">
                        <i class="bi bi-person"></i>Profile
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@navCls("/Member/Notifications")" asp-page="/Member/Notifications">
                        <i class="bi bi-bell"></i>Notifications
                        @if (unreadCount > 0)
                        {
                            <span class="badge rounded-pill bg-danger ms-auto" style="font-size:0.65rem;">@unreadCount</span>
                        }
                    </a>
                </li>
            </ul>
        </nav>

        <main class="flex-grow-1 p-4" style="min-width:0;">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - FitnessClub &mdash; Stay fit, stay strong!
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
