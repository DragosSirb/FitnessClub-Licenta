@using Microsoft.AspNetCore.Identity
@using FitnessClub.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);

    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle fs-5"></i>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
            @if (User.IsInRole("member"))
            {
                <li><a class="dropdown-item" asp-page="/Member/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Panou principal</a></li>
                <li><a class="dropdown-item" asp-page="/Member/Profile"><i class="bi bi-person me-2"></i>Profilul meu</a></li>
                <li><a class="dropdown-item" asp-page="/Member/Subscription"><i class="bi bi-credit-card me-2"></i>Abonamentul meu</a></li>
                <li><a class="dropdown-item" asp-page="/Member/Orders"><i class="bi bi-bag me-2"></i>Comenzile mele</a></li>
            }
            else if (User.IsInRole("trainer"))
            {
                <li><a class="dropdown-item" asp-page="/Trainer/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Panou principal</a></li>
                <li><a class="dropdown-item" asp-page="/Trainer/Profile"><i class="bi bi-person me-2"></i>Profilul meu</a></li>
            }
            else if (User.IsInRole("admin"))
            {
                <li><a class="dropdown-item" asp-page="/Admin/Dashboard/Index"><i class="bi bi-speedometer2 me-2"></i>Panou de administrare</a></li>
            }
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="dropdown-item text-danger">
                        <i class="bi bi-box-arrow-right me-2"></i>Deconectare
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Conectare</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm ms-2" asp-area="Identity" asp-page="/Account/Register">Înregistrare</a>
    </li>
}
