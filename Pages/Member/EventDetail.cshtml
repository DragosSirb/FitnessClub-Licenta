@page "{id:int}"
@model FitnessClub.Pages.Member.EventDetailModel
@using FitnessClub.Models.Enums
@{
    ViewData["Title"] = Model.Event?.Name ?? "Detalii eveniment";
}

<div class="mb-3">
    <a asp-page="/Member/Events" class="text-decoration-none text-secondary small">
        <i class="bi bi-arrow-left me-1"></i>Înapoi la evenimente
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model.Event == null)
{
    <div class="card p-4 text-center text-muted">Evenimentul nu a fost găsit.</div>
}
else
{
    var spotsLeft = Model.Event.MaxParticipants - Model.Event.Enrollments.Count(e => e.Status == EnrollmentStatus.Confirmed);
    var isEnrolled = Model.MyEnrollment != null;

    <div class="row g-4">
        <div class="col-md-7">
            @if (Model.Event.ImageUrl != null)
            {
                <img src="@Model.Event.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Event.Name" style="max-height:300px;width:100%;object-fit:cover;" />
            }
            <h3>@Model.Event.Name</h3>
            <div class="bg-light rounded p-3 mb-3 border-start border-4 border-primary">
                <p class="mb-0 fs-6 lh-lg text-secondary">@Model.Event.Description</p>
            </div>
            <div class="row g-3 text-muted small mt-1">
                <div class="col-6 d-flex align-items-center gap-2">
                    <i class="bi bi-calendar fs-5"></i>
                    <span>@Model.Event.Date.ToString("dd MMM yyyy")</span>
                </div>
                <div class="col-6 d-flex align-items-center gap-2">
                    <i class="bi bi-clock fs-5"></i>
                    <span>@Model.Event.StartTime.ToString("HH:mm") &ndash; @Model.Event.EndTime.ToString("HH:mm")</span>
                </div>
                <div class="col-6 d-flex align-items-center gap-2">
                    <i class="bi bi-geo-alt fs-5"></i>
                    <span>@Model.Event.Location</span>
                </div>
                <div class="col-6 d-flex align-items-center gap-2">
                    <i class="bi bi-people fs-5"></i>
                    <span>@spotsLeft din @Model.Event.MaxParticipants locuri disponibile</span>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4">
                <div class="mb-3 d-flex justify-content-between align-items-center">
                    <span class="h4 mb-0 fw-bold text-purple">@Model.Event.Price RON</span>
                    <span class="badge @(spotsLeft > 0 ? "bg-success" : "bg-danger")">
                        @(spotsLeft > 0 ? $"{spotsLeft} locuri" : "Complet")
                    </span>
                </div>

                @if (isEnrolled)
                {
                    <div class="alert alert-success mb-3">
                        <i class="bi bi-check-circle me-2"></i>Ești înscris la acest eveniment.
                        <div class="small mt-1 text-muted">
                            Plată: @(Model.MyEnrollment!.PaymentStatus == PaymentStatus.Completed ? "Achitat" : "Neachitat")
                            @if (Model.MyEnrollment.PaymentStatus == PaymentStatus.Pending)
                            {
                                <span>&ndash; plată la recepția sălii</span>
                            }
                        </div>
                    </div>
                    @if (Model.Event.Date >= DateTime.Today)
                    {
                        <form method="post" asp-page-handler="Cancel">
                            <input type="hidden" name="enrollmentId" value="@Model.MyEnrollment!.Id" />
                            <button type="submit" class="btn btn-outline-danger w-100"
                                    onclick="return confirm('Ești sigur că vrei să anulezi înscrierea?')">
                                <i class="bi bi-x-circle me-1"></i>Anulează înscrierea
                            </button>
                        </form>
                    }
                }
                else if (spotsLeft == 0)
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-x-circle fs-3 d-block mb-2"></i>
                        Evenimentul este complet.
                    </div>
                }
                else if (Model.ClientSecret != null)
                {
                    <form id="payment-form">
                        <div id="payment-element"></div>
                        <button id="submit" class="btn btn-primary w-100 mt-3">
                            <span id="button-text">Plătește @Model.Event.Price RON</span>
                        </button>
                        <div id="payment-message" class="text-danger mt-2"></div>
                    </form>
                }
                else
                {
                    <div class="d-grid gap-2">
                        <form method="post" asp-page-handler="Attend">
                            <input type="hidden" name="paymentMethod" value="Online" />
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-credit-card me-1"></i>Plătește online
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Attend">
                            <input type="hidden" name="paymentMethod" value="InPerson" />
                            <button type="submit" class="btn btn-outline-primary w-100">
                                <i class="bi bi-building me-1"></i>Plătește la sală
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (Model.ClientSecret != null)
{
    <script>
        const stripe = Stripe('@Model.PublishableKey');
        const elements = stripe.elements({ clientSecret: '@Model.ClientSecret' });
        const paymentElement = elements.create('payment');
        paymentElement.mount('#payment-element');
        document.getElementById('payment-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const { error } = await stripe.confirmPayment({
                elements,
                confirmParams: { return_url: 'http://localhost:5200/Payment/Success?type=event' }
            });
            if (error) document.getElementById('payment-message').textContent = error.message;
        });
    </script>
}
