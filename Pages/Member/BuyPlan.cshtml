@page
@model FitnessClub.Pages.Member.BuyPlanModel
@{
    ViewData["Title"] = "Confirmă planul";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (Model.Plan == null)
{
    <div class="card p-4 text-center text-muted">Planul nu a fost găsit.</div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="text-muted small mb-4">
                <a asp-page="/Member/Plans" class="text-muted"><i class="bi bi-arrow-left me-1"></i>Înapoi la planuri</a>
            </div>
            <div class="card p-4 mb-3">
                <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Plan selectat</div>
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h4 class="mb-1">@Model.Plan.Name</h4>
                        <p class="text-muted small mb-0">@Model.Plan.Description</p>
                    </div>
                    <div class="text-accent fw-bold fs-4 flex-shrink-0 ms-3">@Model.Plan.Price RON</div>
                </div>
            </div>
            <div class="card p-4">
                @if (Model.ClientSecret == null)
                {
                    <form method="post">
                        <input type="hidden" name="planId" value="@Model.Plan.Id" />
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Metodă de plată</label>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="Online" id="payOnline" checked />
                                <label class="form-check-label" for="payOnline">
                                    <i class="bi bi-credit-card me-1"></i>Online (card)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="InPerson" id="payGym" />
                                <label class="form-check-label" for="payGym">
                                    <i class="bi bi-building me-1"></i>Plată la sală
                                </label>
                            </div>
                        </div>
                        <button class="btn btn-primary w-100">
                            <i class="bi bi-check-circle me-2"></i>Confirmă abonamentul
                        </button>
                    </form>
                }
                else
                {
                    <form id="payment-form">
                        <div id="payment-element"></div>
                        <button id="submit" class="btn btn-primary w-100 mt-3">
                            <div class="spinner hidden" id="spinner"></div>
                            <span id="button-text">Plătește @Model.Plan.Price RON</span>
                        </button>
                        <div id="payment-message" class="hidden text-danger mt-2"></div>
                    </form>
                }
            </div>
        </div>
    </div>
}

@if (Model.ClientSecret != null)
{
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        const stripe = Stripe('@Model.PublishableKey');
        const clientSecret = '@Model.ClientSecret';
        const elements = stripe.elements({ clientSecret });
        const paymentElement = elements.create('payment');
        paymentElement.mount('#payment-element');
        const form = document.getElementById('payment-form');
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const { error } = await stripe.confirmPayment({
                elements,
                confirmParams: { return_url: 'http://localhost:5200/Payment/Success?type=subscription' }
            });
            if (error) document.getElementById('payment-message').textContent = error.message;
        });
    </script>
}
