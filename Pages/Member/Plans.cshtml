@page
@model FitnessClub.Pages.Member.PlansModel
@{
    ViewData["Title"] = "Planuri";
}

<div class="text-center mb-5">
    <h2 class="mb-2">Alege-ți planul</h2>
    <p class="text-muted">Compară opțiunile și alege ce se potrivește cel mai bine obiectivelor tale.</p>
</div>

<div class="row justify-content-center g-3">
    @foreach (var plan in Model.Plans)
    {
        <div class="col-md-4 col-sm-6">
            <a asp-page="/Member/BuyPlan" asp-route-planId="@plan.Id" class="card p-4 h-100 d-flex flex-column text-decoration-none">
                <div class="mb-3">
                    <h5 class="mb-1">@plan.Name</h5>
                    <div class="text-accent fw-bold fs-3">@plan.Price <span class="text-muted fs-6 fw-normal">RON</span></div>
                </div>
                <p class="text-muted flex-grow-1">@plan.Description</p>
                <div class="mt-3 pt-3" style="border-top:1px solid var(--border)">
                    @if (plan.IncludesGroupClasses)
                    {
                        <span class="badge bg-success me-1"><i class="bi bi-check me-1"></i>Clase incluse</span>
                    }
                    <span class="badge bg-secondary">@plan.DurationDays zile</span>
                </div>
            </a>
        </div>
    }
</div>
