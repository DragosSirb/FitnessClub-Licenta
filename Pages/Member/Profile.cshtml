@page
@model FitnessClub.Pages.Member.ProfileModel
@{
    ViewData["Title"] = "Profilul meu";
}

<h2 class="mb-4">Profilul meu</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["PasswordSuccess"] != null)
{
    <div class="alert alert-success">@TempData["PasswordSuccess"]</div>
}
@if (TempData["PasswordError"] != null)
{
    <div class="alert alert-danger">@TempData["PasswordError"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card p-4 mb-4">
            <h5 class="mb-3">Informații personale</h5>
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3 text-center">
                    @if (Model.CurrentPhotoUrl != null)
                    {
                        <img src="@Model.CurrentPhotoUrl" class="rounded-circle mb-2" width="100" height="100" style="object-fit:cover" alt="Profil" />
                    }
                    else
                    {
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center text-white mb-2" style="width:100px;height:100px;background-color:##1f6f4a;font-size:2rem">
                            <i class="bi bi-person"></i>
                        </div>
                    }
                    <br />
                    <input type="file" asp-for="Input.ProfilePhoto" class="form-control mt-2" accept="image/*" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Prenume *</label>
                        <input class="form-control" asp-for="Input.FirstName" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nume *</label>
                        <input class="form-control" asp-for="Input.LastName" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Telefon *</label>
                    <input class="form-control" asp-for="Input.Phone" />
                    <span asp-validation-for="Input.Phone" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Adresă *</label>
                    <input class="form-control" asp-for="Input.Address" />
                    <span asp-validation-for="Input.Address" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Greutate țintă (kg)</label>
                    <input class="form-control" asp-for="Input.GoalWeight" type="number" step="0.1" min="0" />
                </div>
                <button type="submit" class="btn btn-primary">Salvează modificările</button>
            </form>
        </div>

        <div class="card p-4">
            <h5 class="mb-3">Schimbă parola</h5>
            <form method="post" asp-page-handler="ChangePassword">
                <div class="mb-3">
                    <label class="form-label">Parola curentă</label>
                    <input class="form-control" asp-for="PasswordInput.CurrentPassword" type="password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Parolă nouă</label>
                    <input class="form-control" asp-for="PasswordInput.NewPassword" type="password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirmă noua parolă</label>
                    <input class="form-control" asp-for="PasswordInput.ConfirmNewPassword" type="password" />
                </div>
                <button type="submit" class="btn btn-outline-primary">Schimbă parola</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
