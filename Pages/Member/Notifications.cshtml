@page
@model FitnessClub.Pages.Member.NotificationsModel
@using FitnessClub.Models.Enums
@{
    ViewData["Title"] = "Notificări";
    var filters = new[] {
        ("", "Toate"),
        ("Session", "Sesiuni"),
        ("Subscription", "Abonamente"),
        ("Event", "Evenimente"),
        ("Order", "Comenzi")
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Notificări</h2>
    @if (Model.Notifications.Any())
    {
        <form method="post" asp-page-handler="DeleteAll">
            <button type="submit" class="btn btn-sm btn-outline-danger"
                    onclick="return confirm('Ștergi toate notificările?')">
                <i class="bi bi-trash me-1"></i>Șterge toate
            </button>
        </form>
    }
</div>

<div class="mb-3 d-flex flex-wrap gap-2">
    @foreach (var (value, label) in filters)
    {
        <a asp-page="/Member/Notifications" asp-route-typeFilter="@value"
           class="btn btn-sm @(Model.TypeFilter == value || (string.IsNullOrEmpty(value) && string.IsNullOrEmpty(Model.TypeFilter)) ? "btn-primary" : "btn-outline-secondary")">
            @label
        </a>
    }
</div>

@if (!Model.Notifications.Any())
{
    <div class="card p-5 text-center">
        <i class="bi bi-bell-slash fs-1 text-muted d-block mb-2"></i>
        <p class="text-muted mb-0">
            @if (string.IsNullOrEmpty(Model.TypeFilter))
            {
                <span>Nu ai notificări.</span>
            }
            else
            {
                <span>Nu există notificări în această categorie.</span>
            }
        </p>
    </div>
}
else
{
    @foreach (var n in Model.Notifications)
    {
        <div class="card mb-2 @(!n.IsRead ? "border-primary" : "")">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div class="d-flex gap-3">
                    <div>
                        @switch (n.Type)
                        {
                            case NotificationType.Session:
                                <i class="bi bi-calendar-check fs-4 text-primary"></i>
                                break;
                            case NotificationType.Subscription:
                                <i class="bi bi-credit-card fs-4 text-success"></i>
                                break;
                            case NotificationType.Event:
                                <i class="bi bi-stars fs-4 text-warning"></i>
                                break;
                            case NotificationType.Order:
                                <i class="bi bi-bag fs-4 text-info"></i>
                                break;
                            default:
                                <i class="bi bi-bell fs-4 text-secondary"></i>
                                break;
                        }
                    </div>
                    <div>
                        <h6 class="mb-1">
                            @n.Title
                            @if (!n.IsRead)
                            {
                                <span class="badge bg-primary ms-2 small">Nou</span>
                            }
                        </h6>
                        <p class="mb-1 small">@n.Message</p>
                        <span class="text-muted" style="font-size:0.8rem">@n.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                        @if (n.Link != null)
                        {
                            <a href="@n.Link" class="ms-2 small">Vezi</a>
                        }
                    </div>
                </div>
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" value="@n.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Șterge">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            </div>
        </div>
    }
}
