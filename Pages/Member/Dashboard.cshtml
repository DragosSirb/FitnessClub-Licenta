@page
@using FitnessClub.Models.Enums
@model FitnessClub.Pages.Members.DashboardModel
@{
    ViewData["Title"] = "Panou";
}

@if (Model.ActiveSubscription != null && (Model.ActiveSubscription.EndDate - DateTime.Today).Days <= 7)
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
        <i class="bi bi-hourglass-split fs-5 flex-shrink-0"></i>
        <div>
            Abonamentul tău expiră în <strong>@((Model.ActiveSubscription.EndDate - DateTime.Today).Days) zile</strong>.
            <a asp-page="/Member/Plans" class="alert-link ms-1">Reînnoiește acum</a>
        </div>
    </div>
}

@if (Model.HasPendingPayments)
{
    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
        <i class="bi bi-exclamation-triangle fs-5 flex-shrink-0"></i>
        <div>Ai plăți în așteptare. Te rugăm să achiți la recepția sălii.</div>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h3 class="fw-bold mb-1">Salutare, @Model.CurrentMember?.FirstName! 👋</h3>
        @if (Model.RandomQuote != null)
        {
            <p class="text-muted mb-0 fst-italic small">
                "@Model.RandomQuote.Text"
                @if (!string.IsNullOrWhiteSpace(Model.RandomQuote.Author) && Model.RandomQuote.Author.ToLower() != "unknown")
                {
                    <span class="fw-semibold ms-1">— @Model.RandomQuote.Author</span>
                }
            </p>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-6">
        <div class="card h-100 p-4">
            <div class="text-muted small fw-semibold text-uppercase mb-3" style="letter-spacing:.06em">Abonamentul tău</div>
            @if (Model.ActiveSubscription != null)
            {
                var daysLeft = (Model.ActiveSubscription.EndDate - DateTime.Today).Days;
                var totalDays = Math.Max(1, (Model.ActiveSubscription.EndDate - Model.ActiveSubscription.StartDate).Days);
                var pct = Math.Min(100, (int)((DateTime.Today - Model.ActiveSubscription.StartDate).Days * 100.0 / totalDays));
                var barColor = daysLeft <= 7 ? "bg-danger" : daysLeft <= 14 ? "bg-warning" : "bg-success";
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-bold fs-5">@Model.ActiveSubscription.Plan.Name</span>
                    <span class="badge bg-success">Activ</span>
                </div>
                <div class="progress mb-2">
                    <div class="progress-bar @barColor" style="width:@pct%"></div>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span>@Model.ActiveSubscription.StartDate.ToString("dd MMM")</span>
                    <span class="@(daysLeft <= 7 ? "text-danger fw-semibold" : "")">@daysLeft zile rămase</span>
                    <span>@Model.ActiveSubscription.EndDate.ToString("dd MMM")</span>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted">Nu ai niciun plan activ.</span>
                    <a asp-page="/Member/Plans" class="btn btn-outline-primary btn-sm">Vezi planuri</a>
                </div>
            }
        </div>
    </div>
    <div class="col-6 col-md-3 col-lg-3">
        <div class="card h-100 p-4 text-center">
            <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Sesiuni</div>
            <div class="display-6 fw-bold text-accent">@Model.TotalSessions</div>
            <div class="text-muted small mt-1">finalizate</div>
        </div>
    </div>
    <div class="col-6 col-md-3 col-lg-3">
        <div class="card h-100 p-4 text-center">
            <div class="text-muted small fw-semibold text-uppercase mb-2" style="letter-spacing:.06em">Clase</div>
            <div class="display-6 fw-bold text-accent">@Model.TotalClasses</div>
            <div class="text-muted small mt-1">participări</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Sesiuni viitoare</span>
                <a asp-page="/Member/BookSession" asp-route-tab="my" class="btn btn-outline-primary btn-sm">Vezi toate</a>
            </div>
            @if (!Model.UpcomingSessions.Any())
            {
                <div class="card-body text-center py-5">
                    <i class="bi bi-calendar-x fs-2 text-muted d-block mb-3"></i>
                    <p class="text-muted mb-3">Nu ai sesiuni programate.</p>
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a asp-page="/Member/BookSession" class="btn btn-primary btn-sm">Rezervă o sesiune</a>
                        <a asp-page="/Member/Classes" class="btn btn-outline-secondary btn-sm">Clase de grup</a>
                    </div>
                </div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var session in Model.UpcomingSessions)
                    {
                        var isConfirmed = session.Status == SessionStatus.Confirmed;
                        var hasPendingPayment = session.PaymentStatus == PaymentStatus.Pending;
                        <li class="list-group-item d-flex align-items-center gap-3 py-3" style="border-left: 3px solid @(isConfirmed ? "var(--green)" : "var(--amber)")">
                            <div class="text-center flex-shrink-0" style="min-width:52px">
                                <div class="fw-bold text-accent" style="font-size:1.2rem;line-height:1">@session.Date.Day</div>
                                <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase">@session.Date.ToString("MMM")</div>
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold small">@session.Trainer.FirstName @session.Trainer.LastName</div>
                                <div class="text-muted" style="font-size:0.8rem">
                                    <i class="bi bi-clock me-1"></i>@session.StartTime.ToString("HH:mm")
                                    &middot; @session.DurationMinutes min
                                </div>
                            </div>
                            <div class="d-flex flex-column align-items-end gap-1">
                                <span class="badge @(isConfirmed ? "bg-success" : "bg-warning")">
                                    @(isConfirmed ? "Confirmat" : "În așteptare")
                                </span>
                                @if (hasPendingPayment)
                                {
                                    <span class="badge bg-danger" style="font-size:0.68rem">Plată la recepție</span>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header fw-semibold">Acțiuni rapide</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-page="/Member/BookSession" class="btn btn-outline-primary w-100 text-start">
                    <i class="bi bi-calendar-plus me-2"></i>Rezervă sesiune personală
                </a>
                <a asp-page="/Member/Classes" class="btn btn-outline-primary w-100 text-start">
                    <i class="bi bi-people me-2"></i>Programa clase de grup
                </a>
                <a asp-page="/Member/Events" class="btn btn-outline-primary w-100 text-start">
                    <i class="bi bi-stars me-2"></i>Evenimente viitoare
                </a>
                <a asp-page="/Member/Progress" asp-route-log="true" class="btn btn-outline-secondary w-100 text-start">
                    <i class="bi bi-graph-up me-2"></i>Adaugă măsurători
                </a>
                <a asp-page="/Shop/Index" class="btn btn-outline-secondary w-100 text-start">
                    <i class="bi bi-bag me-2"></i>Magazin
                </a>
            </div>
        </div>
    </div>
</div>
